{
  "name": "submit_questions",
  "description": "Submit exactly 8 quiz questions for the passage. Always call this tool — never return questions as plain text or markdown.",
  "input_schema": {
    "type": "object",
    "properties": {
      "questions": {
        "type": "array",
        "minItems": 8,
        "maxItems": 8,
        "description": "Exactly 8 questions, indexed 0-7.",
        "items": {
          "type": "object",
          "properties": {
            "index": {
              "type": "integer",
              "minimum": 0,
              "maximum": 7,
              "description": "Zero-based position of this question in the set."
            },
            "cognitiveLevel": {
              "type": "string",
              "enum": [
                "recall",
                "vocabulary",
                "cause_and_effect",
                "inference",
                "application",
                "prerequisite_review"
              ],
              "description": "Bloom-style cognitive level this question targets."
            },
            "conceptTag": {
              "type": "string",
              "description": "Must exactly match one of the concept tags provided in the prompt, or the subtopic_general fallback tag."
            },
            "difficulty": {
              "type": "number",
              "minimum": 0,
              "maximum": 1,
              "description": "Estimated difficulty: 0.2 = very easy, 0.5 = medium, 0.8 = very hard."
            },
            "question": {
              "type": "string",
              "description": "The question stem. Must be answerable from the passage alone."
            },
            "options": {
              "type": "array",
              "minItems": 4,
              "maxItems": 4,
              "items": { "type": "string" },
              "description": "Exactly 4 options, each prefixed with 'A. ', 'B. ', 'C. ', 'D. '."
            },
            "correctIndex": {
              "type": "integer",
              "minimum": 0,
              "maximum": 3,
              "description": "Index (0-3) of the single correct option."
            },
            "explanation": {
              "type": "string",
              "description": "Why the correct answer is right, referencing the exact passage line."
            }
          },
          "required": [
            "index",
            "cognitiveLevel",
            "conceptTag",
            "difficulty",
            "question",
            "options",
            "correctIndex",
            "explanation"
          ]
        }
      }
    },
    "required": ["questions"]
  }
}
