generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model Student {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions          Session[]
  quizAttempts      QuizAttempt[]
  subtopicMasteries SubtopicMastery[]
  conceptMasteries  ConceptMastery[]
}

model Subtopic {
  id                 String @id
  topicId            String
  name               String
  order              Int
  keyConceptsSummary String
  classLevel         Int
  subject            String

  @@unique([topicId, order])

  sessions       Session[]
  masteryRecords SubtopicMastery[]
  concepts       Concept[]
}

model Concept {
  id         String @id
  subtopicId String
  name       String
  tag        String

  subtopic         Subtopic         @relation(fields: [subtopicId], references: [id])
  conceptMasteries ConceptMastery[]

  @@unique([subtopicId, tag])
}

model ConceptMastery {
  id        String @id @default(cuid())
  studentId String
  conceptId String

  mastery            Float    @default(0)
  lastScore          Float    @default(0)
  previousScore      Float    @default(0)
  velocity           Float    @default(0)
  scoreVariance      Float    @default(0)
  consecutiveCorrect Int      @default(0)
  consecutiveWrong   Int      @default(0)
  attempts           Int      @default(0)
  lastAttempted      DateTime?
  retentionScore     Float    @default(1.0)
  halfLifeDays       Float    @default(1.0)
  recallScore        Float    @default(0)
  vocabularyScore    Float    @default(0)
  causeEffectScore   Float    @default(0)
  inferenceScore     Float    @default(0)
  applicationScore   Float    @default(0)

  student Student @relation(fields: [studentId], references: [id])
  concept Concept @relation(fields: [conceptId], references: [id])

  @@unique([studentId, conceptId])
}

model SubtopicMastery {
  id            String    @id @default(cuid())
  studentId     String
  subtopicId    String
  mastery       Float     @default(0)
  attempts      Int       @default(0)
  isComplete    Boolean   @default(false)
  lastAttempted DateTime?
  trend         String?

  student  Student  @relation(fields: [studentId], references: [id])
  subtopic Subtopic @relation(fields: [subtopicId], references: [id])

  @@unique([studentId, subtopicId])
}

model Session {
  id           String   @id @default(cuid())
  studentId    String
  subtopicId   String
  topicId      String
  neo4jTopicId String
  classLevel   Int
  passage      String
  questions    Json
  questionPool   Json   @default("[]")
  shownQuestions Json   @default("[]")
  pendingRetries Json   @default("[]")
  sessionStatus  String @default("active")
  totalShown     Int    @default(0)
  totalCorrect   Int    @default(0)
  createdAt    DateTime @default(now())

  student     Student      @relation(fields: [studentId], references: [id])
  subtopic    Subtopic     @relation(fields: [subtopicId], references: [id])
  quizAttempt QuizAttempt?
}

model QuizAttempt {
  id        String   @id @default(cuid())
  studentId String
  sessionId String   @unique
  score     Int
  total     Int
  answers   Json
  createdAt DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id])
  session Session @relation(fields: [sessionId], references: [id])
}