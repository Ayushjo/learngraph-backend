generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
 
}

model Student {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions         Session[]
  quizAttempts     QuizAttempt[]
  subtopicMasteries SubtopicMastery[]
}

// Static subtopic definition — mirrors src/data/subtopics.ts
// Seeded once, never changes
model Subtopic {
  id                 String  @id  // e.g. 'c12_electrochemistry_s1'
  topicId            String       // parent chapter neo4j id e.g. 'c12_electrochemistry'
  name               String
  order              Int
  keyConceptsSummary String
  classLevel         Int
  subject            String

  @@unique([topicId, order])

  sessions          Session[]
  masteryRecords    SubtopicMastery[]
}

// Per-student per-subtopic mastery tracking
model SubtopicMastery {
  id            String    @id @default(cuid())
  studentId     String
  subtopicId    String
  mastery       Float     @default(0)
  attempts      Int       @default(0)
  isComplete    Boolean   @default(false)  // mastery >= 0.6 at least once
  lastAttempted DateTime?
  trend         String?   // 'improving' | 'declining' | 'stable'

  student   Student  @relation(fields: [studentId], references: [id])
  subtopic  Subtopic @relation(fields: [subtopicId], references: [id])

  @@unique([studentId, subtopicId])
}

model Session {
  id           String   @id @default(cuid())
  studentId    String
  subtopicId   String   // which subtopic this session is for
  topicId      String   // neo4j topic id (chapter level)
  neo4jTopicId String   // same as topicId — keeping for compatibility
  classLevel   Int
  passage      String
  questions    Json
  createdAt    DateTime @default(now())

  student     Student      @relation(fields: [studentId], references: [id])
  subtopic    Subtopic     @relation(fields: [subtopicId], references: [id])
  quizAttempt QuizAttempt?
}

model QuizAttempt {
  id        String   @id @default(cuid())
  studentId String
  sessionId String   @unique
  score     Int
  total     Int
  answers   Json
  createdAt DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id])
  session Session @relation(fields: [sessionId], references: [id])
}